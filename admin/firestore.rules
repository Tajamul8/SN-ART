rules_version = '2';

// ==========================================================================
// SN ART — Firestore Security Rules  (DEMO MODE)
//
// Paste these into: Firebase Console > Firestore Database > Rules > Publish.
//
// IMPORTANT — this configuration matches the DEMO admin login (fixed phone +
// fixed OTP, no Firebase Authentication). Because the admin panel signs in
// without Firebase Auth, these rules allow product reads AND writes from any
// client. That means ANYONE who can reach your Firestore could modify the
// products collection.
//
// This is acceptable for a demo / MVP. For a real production store you should:
//   1. Restore Firebase phone authentication in admin/admin.js, and
//   2. Replace the products write rule below with `if isAdmin()` (see the
//      commented version), gating writes to signed-in admins only.
// ==========================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Products ----
    match /products/{productId} {
      allow read: if true;     // public catalogue
      allow write: if true;    // DEMO: open writes (no auth). Lock down for production.
    }

    // ---- Orders (created by storefront checkout) ----
    match /orders/{orderId} {
      allow create: if true;   // customers can place orders
      allow read, update, delete: if true; // DEMO: admin reads them in panel
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

